# Application Configuration
FLASK_ENV=development

# Strangler Pattern Configuration
P_VALUE=100  # Percentage of traffic to route to old service (user-service-v1); set to 0 to fully migrate

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=your_queue_name

# Optional: CloudAMQP or full AMQP URL (overrides HOST/PORT/VHOST when set)
RABBITMQ_URL=

# Per-service RabbitMQ credentials (user-service-v1 and user-service-v2)
RABBITMQ_USER_USER=your_rabbitmq_user
RABBITMQ_USER_PASSWORD=your_rabbitmq_password

# Per-service RabbitMQ credentials (order-service)
RABBITMQ_ORDER_USER=your_rabbitmq_user
RABBITMQ_ORDER_PASSWORD=your_rabbitmq_password

# Database Configuration
MONGO_URI=mongodb://your_mongo_username:your_mongo_password@localhost:27017/
# For Docker deployments use "mongodb" as the host, e.g.:
# MONGO_URI=mongodb://your_mongo_username:your_mongo_password@mongodb:27017/

DATABASE_NAME=your_database_name       
ORDER_DATABASE_NAME=orderdb            

MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password
